# Copy to backend/.env and fill in. backend/.env is gitignored — never commit it.
OPENAI_API_KEY=sk-your-key-here

# Optional: override the classification model (default: openai:gpt-5-mini)
# RECIPE_CLASSIFIER_MODEL=openai:gpt-5-mini

# Conversational agent (POST /chat), all optional:
# CHAT_AGENT_MODEL=openai:gpt-5-mini        # model for the chat agent
# CHAT_MODEL_TIMEOUT_SECONDS=60             # per model-request timeout
# CHAT_HISTORY_MAX_MESSAGES=40              # per-session history cap
# CHAT_CORS_ORIGINS=http://localhost:5173   # comma-separated allowed origins

# Voice (speech-to-text + text-to-speech). ElevenLabs is the only provider
# for both; without ELEVENLABS_API_KEY, /transcribe and /speak return 503
# and the app is text-only.
# ELEVENLABS_API_KEY=xi-your-key-here
# ELEVENLABS_STT_MODEL=scribe_v1            # ElevenLabs STT model
# CHAT_STT_LANGUAGE=cs                      # STT language, pinned (not auto-detected)
#                                           # — unhinted STT hallucinates on short audio
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM   # TTS voice (default: Rachel)
# ELEVENLABS_TTS_MODEL=eleven_flash_v2_5     # TTS model
